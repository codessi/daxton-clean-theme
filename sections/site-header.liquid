{%- liquid
  assign menu = section.settings.menu
  assign logo = section.settings.logo
  assign logo_height = section.settings.logo_height
-%}

<header
  class="site-header js-site-header sticky top-0 z-50 border-b border-neutral-200 bg-white"
  style="--logo-max-height: {{ logo_height }}px;"
  {{ section.shopify_attributes }}
>
  <div class="mx-auto flex max-w-7xl items-center gap-3 px-4 py-3 md:gap-6 md:py-4">
    <div class="flex flex-1 items-center md:flex-none md:justify-start">
      <details class="mobile-nav group relative md:hidden">
        <summary class="flex cursor-pointer list-none items-center justify-center rounded-md p-2 text-neutral-900 hover:bg-neutral-100 [&::-webkit-details-marker]:hidden">
          <span class="sr-only">{{ 'layout.menu' | t }}</span>
          {% render 'icon', name: 'menu' %}
        </summary>
        <div class="absolute left-0 top-full z-50 mt-1 w-[min(100vw-2rem,22rem)] rounded-lg border border-neutral-200 bg-white p-4 shadow-lg">
          <nav aria-label="{{ 'layout.menu' | t }}">
            {% if menu != blank %}
              <ul class="flex flex-col gap-1 text-sm">
                {% for link in menu.links %}
                  <li>
                    <a class="block rounded px-2 py-2 font-medium hover:bg-neutral-50" href="{{ link.url }}">{{ link.title | escape }}</a>
                    {% if link.links != blank %}
                      <ul class="ml-2 border-l border-neutral-100 pl-2">
                        {% for child in link.links %}
                          <li>
                            <p class="px-2 py-1 text-xs font-semibold uppercase tracking-wide text-neutral-500">{{ child.title | escape }}</p>
                            {% if child.links != blank %}
                              <ul class="mb-2">
                                {% for grand in child.links %}
                                  <li>
                                    <a class="block rounded px-2 py-1.5 text-neutral-700 hover:bg-neutral-50" href="{{ grand.url }}">{{ grand.title | escape }}</a>
                                  </li>
                                {% endfor %}
                              </ul>
                            {% else %}
                              <a class="mb-2 block rounded px-2 py-1.5 text-neutral-700 hover:bg-neutral-50" href="{{ child.url }}">{{ child.title | escape }}</a>
                            {% endif %}
                          </li>
                        {% endfor %}
                      </ul>
                    {% endif %}
                  </li>
                {% endfor %}
              </ul>
            {% else %}
              <p class="text-sm text-neutral-500">{{ 'layout.menu_empty' | t }}</p>
            {% endif %}
          </nav>
        </div>
      </details>

      <a href="{{ routes.root_url }}" class="flex flex-1 justify-center md:flex-none md:justify-start">
        {% if logo != blank %}
          {{
            logo
            | image_url: width: 600
            | image_tag:
              class: 'site-header__logo h-auto w-auto max-w-[140px] object-contain md:max-w-[180px]',
              widths: '180, 360, 540',
              alt: shop.name
          }}
        {% else %}
          <span class="text-lg font-semibold tracking-tight text-neutral-900 md:text-xl">{{ shop.name }}</span>
        {% endif %}
      </a>
    </div>

    <nav class="hidden flex-1 justify-center self-stretch md:flex md:items-center" aria-label="{{ 'layout.menu' | t }}">
      {% if menu != blank %}
        <ul class="site-header__nav-list flex flex-wrap items-center justify-center gap-1 lg:gap-3">
          {% for link in menu.links %}
            <li class="site-header__nav-item group relative flex items-center">
              <a
                class="site-header__nav-link relative inline-flex items-center px-1 py-2 text-xs font-semibold uppercase tracking-[0.12em] text-neutral-900 lg:px-2 lg:text-sm"
                href="{{ link.url }}"
                {% if link.links != blank %}
                  aria-haspopup="true"
                {% endif %}
              >
                {{ link.title | escape }}
              </a>

              {% if link.links != blank %}
                <div
                  class="mega-menu__panel pointer-events-none invisible fixed left-0 right-0 z-40 opacity-0 shadow-lg transition duration-200 ease-out group-hover:pointer-events-auto group-hover:visible group-hover:opacity-100 group-focus-within:pointer-events-auto group-focus-within:visible group-focus-within:opacity-100"
                  data-mega-panel
                  role="region"
                  aria-label="{{ link.title | escape }}"
                >
                  <div class="mega-menu__bridge pointer-events-auto" aria-hidden="true"></div>
                  <div class="border-t border-neutral-200 bg-white">
                    <div class="mx-auto max-w-7xl px-4 py-10 lg:px-6">
                      <div class="mega-menu__grid lg:grid lg:grid-cols-12 lg:gap-10 lg:items-start">
                        <div class="mega-menu__columns lg:col-span-8">
                          <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-3">
                            {% for child in link.links %}
                              <div class="mega-menu__column">
                                <p class="mega-menu__heading text-xs font-bold uppercase tracking-[0.14em] text-neutral-900">
                                  {{ child.title | escape }}
                                </p>
                                {% if child.links != blank %}
                                  <ul class="mega-menu__list mt-3 space-y-2">
                                    {% for grand in child.links %}
                                      <li>
                                        <a class="mega-menu__link text-sm text-neutral-700 transition hover:text-neutral-950" href="{{ grand.url }}">
                                          {{- grand.title | escape -}}
                                        </a>
                                      </li>
                                    {% endfor %}
                                  </ul>
                                {% else %}
                                  <ul class="mega-menu__list mt-3 space-y-2">
                                    <li>
                                      <a class="mega-menu__link text-sm text-neutral-700 transition hover:text-neutral-950" href="{{ child.url }}">
                                        {{- child.title | escape -}}
                                      </a>
                                    </li>
                                  </ul>
                                {% endif %}
                              </div>
                            {% endfor %}
                          </div>
                        </div>

                        {% liquid
                          assign mega_promo = nil
                          for block in section.blocks
                            if block.type == 'mega_menu_promo'
                              assign ph = block.settings.parent_handle | strip | downcase
                              if ph == link.handle
                                assign mega_promo = block
                                break
                              endif
                            endif
                          endfor
                        %}

                        {% if mega_promo != nil %}
                          <div class="mega-menu__promo mt-10 lg:col-span-4 lg:mt-0" {{ mega_promo.shopify_attributes }}>
                            <a
                              class="group/promo block"
                              href="{{ mega_promo.settings.link | default: '#' }}"
                            >
                              {% if mega_promo.settings.image != blank %}
                                <div class="mega-menu__promo-image aspect-[3/4] w-full overflow-hidden bg-neutral-100">
                                  {{
                                    mega_promo.settings.image
                                    | image_url: width: 800
                                    | image_tag:
                                      class: 'h-full w-full object-cover transition duration-500 group-hover/promo:scale-[1.02]',
                                      loading: 'lazy',
                                      sizes: '(min-width: 1024px) 33vw, 100vw',
                                      widths: '400, 600, 800',
                                      alt: mega_promo.settings.title | escape
                                  }}
                                </div>
                              {% endif %}
                              {% if mega_promo.settings.title != blank %}
                                <span class="mt-3 block text-center text-xs font-bold uppercase tracking-[0.14em] text-neutral-900 underline-offset-4 group-hover/promo:underline">
                                  {{ mega_promo.settings.title | escape }}
                                </span>
                              {% endif %}
                            </a>
                          </div>
                        {% endif %}
                      </div>
                    </div>
                  </div>
                </div>
              {% endif %}
            </li>
          {% endfor %}
        </ul>
      {% endif %}
    </nav>

    <div class="flex flex-1 items-center justify-end gap-1 md:max-w-none md:flex-none md:gap-2">
      {% if section.settings.show_search %}
        <form
          action="{{ routes.search_url }}"
          method="get"
          role="search"
          class="mr-1 hidden max-w-[11rem] items-center gap-2 border-b border-neutral-300 pb-1 lg:flex lg:max-w-[14rem]"
        >
          <label class="sr-only" for="SiteHeaderSearchInline">{{ 'layout.search' | t }}</label>
          <input
            id="SiteHeaderSearchInline"
            class="min-w-0 flex-1 bg-transparent text-sm text-neutral-900 outline-none placeholder:text-neutral-400"
            type="search"
            name="q"
            placeholder="{{ 'layout.search_placeholder' | t }}"
            autocomplete="off"
          >
          <button type="submit" class="shrink-0 text-neutral-900" aria-label="{{ 'layout.search' | t }}">
            {% render 'icon', name: 'search' %}
          </button>
        </form>
        <details class="search-pop group relative lg:hidden">
          <summary class="flex cursor-pointer list-none items-center justify-center rounded-md p-2 text-neutral-900 hover:bg-neutral-100 [&::-webkit-details-marker]:hidden">
            <span class="sr-only">{{ 'layout.search' | t }}</span>
            {% render 'icon', name: 'search' %}
          </summary>
          <div class="absolute right-0 top-full z-50 mt-2 w-[min(calc(100vw-2rem),20rem)] rounded-lg border border-neutral-200 bg-white p-3 shadow-lg">
            <form action="{{ routes.search_url }}" method="get" role="search">
              <label class="sr-only" for="SiteHeaderSearch">{{ 'layout.search' | t }}</label>
              <input
                id="SiteHeaderSearch"
                class="w-full rounded border border-neutral-300 px-3 py-2 text-sm"
                type="search"
                name="q"
                placeholder="{{ 'layout.search_placeholder' | t }}"
              >
              <button type="submit" class="mt-2 w-full rounded bg-neutral-900 px-3 py-2 text-sm font-medium text-white">
                {{ 'layout.search' | t }}
              </button>
            </form>
          </div>
        </details>
      {% endif %}

      {% if section.settings.favorite_teams_url != blank %}
        <a
          class="hidden items-center gap-1.5 rounded-md px-1 py-2 text-xs font-semibold uppercase tracking-wide text-neutral-900 hover:bg-neutral-100 sm:flex"
          href="{{ section.settings.favorite_teams_url }}"
        >
          {% render 'icon', name: 'heart' %}
          <span class="hidden xl:inline">{{ 'layout.favorite_teams' | t }}</span>
        </a>
      {% endif %}

      <a
        class="hidden items-center justify-center rounded-md p-2 text-neutral-900 hover:bg-neutral-100 sm:flex"
        href="{{ routes.account_url }}"
      >
        <span class="sr-only">{{ 'layout.account' | t }}</span>
        {% render 'icon', name: 'user' %}
      </a>

      <a class="relative flex items-center justify-center rounded-md p-2 text-neutral-900 hover:bg-neutral-100" href="{{ routes.cart_url }}">
        <span class="sr-only">{{ 'layout.cart' | t }}</span>
        {% render 'icon', name: 'cart' %}
        {% if cart.item_count > 0 %}
          <span class="absolute -right-0.5 -top-0.5 flex h-4 min-w-4 items-center justify-center rounded-full bg-neutral-900 px-1 text-[10px] font-semibold text-white">
            {{ cart.item_count }}
          </span>
        {% endif %}
      </a>
    </div>
  </div>
</header>

{% stylesheet %}
  .site-header__logo {
    max-height: var(--logo-max-height, 48px);
  }

  .site-header__nav-link::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0;
    height: 2px;
    width: 100%;
    background-color: currentColor;
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .site-header__nav-item:hover .site-header__nav-link::after,
  .site-header__nav-item:focus-within .site-header__nav-link::after {
    transform: scaleX(1);
  }

  .mega-menu__bridge {
    height: 0.5rem;
  }

  .mega-menu__panel {
    top: var(--mega-menu-top, 5rem);
  }

  .site-header__nav-item:has([data-mega-panel])::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    top: 100%;
    height: 2rem;
    z-index: 35;
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    var header = document.querySelector('.js-site-header');
    if (!header) return;

    function setMegaTop() {
      var rect = header.getBoundingClientRect();
      document.documentElement.style.setProperty('--mega-menu-top', rect.bottom + 'px');
    }

    setMegaTop();
    window.addEventListener('resize', setMegaTop);
    window.addEventListener('scroll', setMegaTop, { passive: true });
    if (document.fonts && document.fonts.ready) {
      document.fonts.ready.then(setMegaTop);
    }
    document.addEventListener('shopify:section:load', setMegaTop);
  })();
{% endjavascript %}

{% schema %}
{
  "name": "Header",
  "class": "section-site-header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "range",
      "id": "logo_height",
      "min": 24,
      "max": 120,
      "step": 2,
      "unit": "px",
      "label": "Logo max height",
      "default": 48
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Main menu"
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "label": "Show search",
      "default": true
    },
    {
      "type": "url",
      "id": "favorite_teams_url",
      "label": "Favorite teams link",
      "info": "Optional. Shows heart icon + label on large screens."
    }
  ],
  "blocks": [
    {
      "type": "mega_menu_promo",
      "name": "Mega menu promo",
      "settings": [
        {
          "type": "text",
          "id": "parent_handle",
          "label": "Top-level menu item handle",
          "info": "Must match the handle of a parent link (e.g. headwear). Find it in Navigation by editing the menu link URL slug."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Caption",
          "default": "Featured collection"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [{ "name": "Header" }]
}
{% endschema %}
