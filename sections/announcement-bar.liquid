{%- if section.settings.message != blank -%}
  <div
    class="bg-[var(--announcement-bg)] text-[var(--announcement-fg)] text-center text-sm font-medium tracking-wide"
    style="--announcement-bg: {{ section.settings.background_color }}; --announcement-fg: {{ section.settings.text_color }};"
    {{ section.shopify_attributes }}
  >
    <div class="mx-auto flex max-w-7xl flex-wrap items-center justify-center gap-2 px-4 py-2.5">
      {%- if section.settings.link != blank -%}
        <a href="{{ section.settings.link }}" class="text-inherit underline-offset-2 hover:underline">
          {{ section.settings.message | escape }}
        </a>
      {%- else -%}
        <span>{{ section.settings.message | escape }}</span>
      {%- endif -%}
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Announcement bar",
  "class": "section-announcement-bar",
  "settings": [
    {
      "type": "text",
      "id": "message",
      "label": "Message",
      "default": "Free shipping on all orders."
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#ffffff"
    }
  ],
  "presets": [{ "name": "Announcement bar" }]
}
{% endschema %}
