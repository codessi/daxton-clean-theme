{% if section.settings.heading != blank or section.blocks.size > 0 %}
  <section class="featured-collections bg-neutral-50 py-12 md:py-16" {{ section.shopify_attributes }}>
    <div class="mx-auto max-w-7xl px-4">
      {% if section.settings.heading != blank %}
        <h2 class="mb-8 text-center text-2xl font-semibold tracking-tight text-neutral-900 md:text-3xl">
          {{ section.settings.heading | escape }}
        </h2>
      {% endif %}

      {% if section.blocks.size > 0 %}
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
          {% for block in section.blocks %}
            {% case block.type %}
              {% when 'collection' %}
                {%- liquid
                  assign coll = block.settings.collection
                  assign title = block.settings.title
                  if title == blank and coll != blank
                    assign title = coll.title
                  endif
                  assign image = block.settings.image
                  if image == blank and coll != blank and coll.featured_image
                    assign image = coll.featured_image
                  endif
                -%}
                {% if coll != blank %}
                  <a
                    class="group block overflow-hidden rounded-xl border border-neutral-200 bg-white shadow-sm transition hover:shadow-md"
                    href="{{ coll.url }}"
                    {{ block.shopify_attributes }}
                  >
                    <div class="aspect-[4/3] overflow-hidden bg-neutral-100">
                      {% if image != blank %}
                        {{
                          image
                          | image_url: width: 800
                          | image_tag:
                            class: 'h-full w-full object-cover transition duration-500 group-hover:scale-105',
                            loading: 'lazy',
                            alt: title | escape
                        }}
                      {% endif %}
                    </div>
                    <div class="p-4">
                      {% if title != blank %}
                        <h3 class="text-lg font-semibold text-neutral-900">{{ title | escape }}</h3>
                      {% endif %}
                      {% if block.settings.description != blank %}
                        <p class="mt-2 line-clamp-3 text-sm text-neutral-600">{{ block.settings.description | escape }}</p>
                      {% endif %}
                    </div>
                  </a>
                {% endif %}
            {% endcase %}
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </section>
{% endif %}

{% schema %}
{
  "name": "Featured collections",
  "class": "section-featured-collection-row",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured collections"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Custom title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured collections",
      "blocks": [
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" }
      ]
    }
  ]
}
{% endschema %}
