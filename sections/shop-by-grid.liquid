{% if section.settings.heading != blank or section.blocks.size > 0 %}
  <section class="shop-by-grid bg-white py-12 md:py-16" {{ section.shopify_attributes }}>
    <div class="mx-auto max-w-7xl px-4">
      {% if section.settings.heading != blank %}
        <h2 class="mb-8 text-center text-2xl font-semibold tracking-tight text-neutral-900 md:text-3xl">
          {{ section.settings.heading | escape }}
        </h2>
      {% endif %}

      {% if section.blocks.size > 0 %}
        <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6">
          {% for block in section.blocks %}
            {% case block.type %}
              {% when 'tile' %}
                <a
                  class="group flex flex-col items-center rounded-lg border border-transparent p-3 text-center transition hover:border-neutral-200 hover:shadow-sm"
                  href="{{ block.settings.link | default: '#' }}"
                  {{ block.shopify_attributes }}
                >
                  {% if block.settings.image != blank %}
                    <div class="mb-3 aspect-square w-full max-w-[120px] overflow-hidden rounded-full bg-neutral-100">
                      {{
                        block.settings.image
                        | image_url: width: 400
                        | image_tag:
                          class: 'h-full w-full object-cover transition group-hover:scale-105',
                          loading: 'lazy',
                          alt: block.settings.title | escape
                      }}
                    </div>
                  {% else %}
                    <div class="mb-3 aspect-square w-full max-w-[120px] rounded-full bg-neutral-200"></div>
                  {% endif %}
                  {% if block.settings.title != blank %}
                    <span class="text-sm font-medium text-neutral-800 group-hover:underline">{{ block.settings.title | escape }}</span>
                  {% endif %}
                </a>
            {% endcase %}
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </section>
{% endif %}

{% schema %}
{
  "name": "Shop by grid",
  "class": "section-shop-by-grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by team"
    }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "Tile",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "League"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop by grid",
      "blocks": [
        { "type": "tile", "settings": { "title": "MLB" } },
        { "type": "tile", "settings": { "title": "NFL" } },
        { "type": "tile", "settings": { "title": "NBA" } },
        { "type": "tile", "settings": { "title": "NHL" } },
        { "type": "tile", "settings": { "title": "NCAA" } },
        { "type": "tile", "settings": { "title": "More" } }
      ]
    }
  ]
}
{% endschema %}
